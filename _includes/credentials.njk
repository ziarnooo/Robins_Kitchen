<section class="credentials">
  <div class="credentials-inner">
    <div class="label">Studied · Cooked · Hosted</div>
    <h2>Twenty years <em>at the bench</em>,<br>and a few good kitchens along the way.</h2>
    <div class="creds-grid">
      <div class="creds-col">
        <h3>Studied at</h3>
        <ul>
          {% for item in credentials.studied_at %}
          <li>{{ item.name }} <em>— {{ item.place }}</em></li>
          {% endfor %}
        </ul>
      </div>
      <div class="creds-col">
        <h3>Cooked alongside</h3>
        <ul>
          {% for item in credentials.cooked_alongside %}
          <li>{{ item.name }} <em>— {{ item.place }}</em></li>
          {% endfor %}
        </ul>
      </div>
    </div>
  </div>
</section>
